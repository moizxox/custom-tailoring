                  "const json = pm.response.json();",
                  "if (Array.isArray(json) && json.length > 0) {",
                  "  pm.collectionVariables.set('lani_media_id', json[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{lani_base_url}}/admin/api/upload"
          }
        },
        {
          "name": "Upload Image",
