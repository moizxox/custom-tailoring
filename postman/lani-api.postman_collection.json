{
  "info": {
    "_postman_id": "lani-cms-api-collection",
    "name": "Lani Kostümschneiderei API",
    "description": "Full API collection for Lani CMS (admin) and customer portal.\n\n## Quick start\n1. Import this collection\n2. Run folder **0. Demo Data Init** top-to-bottom in Collection Runner\n3. All variables use the `lani_` prefix\n\n## Auth\n- **Admin CMS**: NextAuth cookie `authjs.session-token` → stored in `{{lani_session_token}}`\n- **Customer portal**: HMAC cookie `portal_session` → stored in `{{lani_portal_session_token}}`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "lani_base_url", "value": "http://localhost:3000" },
    { "key": "lani_admin_email", "value": "mainmoiz899@gmail.com" },
    { "key": "lani_admin_password", "value": "Admin@123" },
    { "key": "lani_csrf_token", "value": "" },
    { "key": "lani_session_token", "value": "" },
    { "key": "lani_admin_user_id", "value": "" },
    { "key": "lani_admin_user_email", "value": "" },
    { "key": "lani_portal_email", "value": "max@example.com" },
    { "key": "lani_portal_access_code", "value": "LANI2026" },
    { "key": "lani_portal_session_token", "value": "" },
    { "key": "lani_product_id", "value": "" },
    { "key": "lani_product_slug", "value": "demo-postman-kostum" },
    { "key": "lani_page_slug", "value": "home" },
    { "key": "lani_section_key", "value": "hero" },
    { "key": "lani_media_id", "value": "" },
    { "key": "lani_reset_token", "value": "" },
    { "key": "lani_new_admin_name", "value": "Demo Admin" },
    { "key": "lani_new_admin_email", "value": "demo.admin@lani.test" },
    { "key": "lani_new_admin_password", "value": "DemoAdmin@123" },
    { "key": "lani_demo_timestamp", "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-attach admin session cookie when lani_session_token is set",
          "const laniSession = pm.collectionVariables.get('lani_session_token');",
          "const url = pm.request.url.toString();",
          "const isAdminAuth = url.includes('/api/auth/') && !url.includes('/admin/api/auth/');",
          "if (laniSession && !isAdminAuth && url.includes('/admin/api/')) {",
          "  pm.request.headers.upsert({ key: 'Cookie', value: 'authjs.session-token=' + laniSession });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "0. Demo Data Init (run in order)",
      "description": "Run this entire folder in Collection Runner to authenticate and seed demo CMS data.",
      "item": [
        {
          "name": "[Init] 1. Get CSRF Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('CSRF token received', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.csrfToken).to.be.a('string');",
                  "  pm.collectionVariables.set('lani_csrf_token', json.csrfToken);",
                  "});",
                  "pm.collectionVariables.set('lani_demo_timestamp', Date.now().toString());"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{lani_base_url}}/api/auth/csrf"
          }
        },
        {
          "name": "[Init] 2. Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin login sets session cookie', () => {",
                  "  pm.expect([200, 302]).to.include(pm.response.code);",
                  "});",
                  "",
                  "const headers = pm.response.headers.all();",
                  "headers.filter(h => h.key.toLowerCase() === 'set-cookie').forEach(h => {",
                  "  const match = h.value.match(/authjs\\.session-token=([^;]+)/);",
                  "  if (match) pm.collectionVariables.set('lani_session_token', match[1]);",
                  "});",
                  "",
                  "pm.test('Session token stored', () => {",
                  "  pm.expect(pm.collectionVariables.get('lani_session_token')).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "csrfToken", "value": "{{lani_csrf_token}}" },
                { "key": "email", "value": "{{lani_admin_email}}" },
                { "key": "password", "value": "{{lani_admin_password}}" },
                { "key": "redirect", "value": "false" },
                { "key": "json", "value": "true" }
              ]
            },
            "url": "{{lani_base_url}}/api/auth/callback/credentials"
          }
        },
        {
          "name": "[Init] 3. Verify Admin Session",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const t = pm.collectionVariables.get('lani_session_token');",
                  "if (t) pm.request.headers.upsert({ key: 'Cookie', value: 'authjs.session-token=' + t });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Session is valid', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.user).to.be.an('object');",
                  "  pm.expect(json.user.email).to.eql(pm.collectionVariables.get('lani_admin_email'));",
                  "  if (json.user.id) pm.collectionVariables.set('lani_admin_user_id', json.user.id);",
                  "  if (json.user.email) pm.collectionVariables.set('lani_admin_user_email', json.user.email);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{lani_base_url}}/api/auth/session"
          }
        },
