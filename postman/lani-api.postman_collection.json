    {
      "name": "6. Portal — Customer",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const t = pm.collectionVariables.get('lani_portal_session_token');",
              "if (t) pm.request.headers.upsert({ key: 'Cookie', value: 'portal_session=' + t });"
            ]
          }
        }
      ],
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.headers.all().filter(h => h.key.toLowerCase() === 'set-cookie').forEach(h => {",
                  "  const match = h.value.match(/portal_session=([^;]+)/);",
                  "  if (match) pm.collectionVariables.set('lani_portal_session_token', match[1]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{lani_portal_email}}\",\n  \"accessCode\": \"{{lani_portal_access_code}}\"\n}"
            },
