// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Admin users
// ─────────────────────────────────────────────────────────────────────────────

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Page content — one row per page+section combination
// ─────────────────────────────────────────────────────────────────────────────

model PageContent {
  id         String   @id @default(cuid())
  pageSlug   String
  sectionKey String
  content    Json
  updatedAt  DateTime @updatedAt

  @@unique([pageSlug, sectionKey])
  @@index([pageSlug])
}

// ─────────────────────────────────────────────────────────────────────────────
// Products
// ─────────────────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       String
  category    String
  tier        String
  imageUrl    String?
  galleryUrls Json?
  tierPricing Json?
  inStock     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Media library
// ─────────────────────────────────────────────────────────────────────────────

model MediaFile {
  id        String   @id @default(cuid())
  url       String
  altText   String?
  filename  String
  publicId  String?
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// Site-wide settings (contact, locations, social)
// ─────────────────────────────────────────────────────────────────────────────

model SiteSettings {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Password reset tokens
// ─────────────────────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// Contact form submissions
// ─────────────────────────────────────────────────────────────────────────────

model ContactSubmission {
  id                  String    @id @default(cuid())
  name                String
  email               String
  phone               String?
  location            String?
  message             String
  read                Boolean   @default(false)
  convertedCustomerId String?
  convertedAt         DateTime?
  createdAt           DateTime  @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — Customers
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  accessCode   String   @unique
  passwordHash String?
  role         String   @default("customer") // customer | group_leader
  notes        String?
  location     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  groupMemberships GroupMember[]
  ledGroups        Group[]             @relation("GroupLeader")
  projects         Project[]           @relation("CustomerProjects")
  measurements     Measurement[]
  notifications    Notification[]      @relation("CustomerNotifications")
  portalTokens     PortalAccessToken[]

  @@index([email])
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — Groups (Guggenmusik, Cliquen, teams)
// ─────────────────────────────────────────────────────────────────────────────

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("group") // group | guggenmusik | clique | verein
  season      String? // e.g. "Fasnacht 2026"
  leaderId    String?
  location    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leader   Customer?     @relation("GroupLeader", fields: [leaderId], references: [id])
  members  GroupMember[]
  projects Project[]     @relation("GroupProjects")

  @@index([leaderId])
}

model GroupMember {
  id                String   @id @default(cuid())
  groupId           String
  customerId        String
  costumeVariant    String?
  measurementStatus String   @default("pending") // pending | partial | complete | checked
  notes             String?
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())

  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([groupId, customerId])
  @@index([groupId])
  @@index([customerId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — Projects
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id              String    @id @default(cuid())
  title           String
  description     String?
  customerId      String?
  groupId         String?
  /// Body/fit category for Massblatt: Herren | Damen | Kinder | Mixed
  costumeCategory String?
  /// Order type: guggenmusik | clique | verein | familie | einzelperson | schnitzelbaengg | other
  orderType       String?
  quantity        Int       @default(1)
  /// Abholtermin 1
  deadline        DateTime?
  /// Abholtermin 2
  deliveryDate    DateTime?

  // Public status (visible to customer)
  customerStatus String @default("request_received")
  // Internal production status (admin only)
  internalStatus String @default("new")

  priority      String   @default("normal") // low | normal | high | urgent
  totalAmount   Decimal? @db.Decimal(10, 2)
  paidAmount    Decimal? @db.Decimal(10, 2)
  paymentStatus String   @default("unpaid") // unpaid | partial | paid

  /// Customer-visible notes
  notes         String?
  /// Admin-only notes
  internalNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer      Customer?      @relation("CustomerProjects", fields: [customerId], references: [id])
  group         Group?         @relation("GroupProjects", fields: [groupId], references: [id])
  measurements  Measurement[]
  conversations Conversation[]
  tasks         Task[]
  files         ProjectFile[]

  @@index([customerId])
  @@index([groupId])
  @@index([customerStatus])
  @@index([internalStatus])
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — Portal Access Tokens (magic-link login)
// ─────────────────────────────────────────────────────────────────────────────

model PortalAccessToken {
  id         String   @id @default(cuid())
  customerId String
  token      String   @unique
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — Customer self-registration (email verification)
// ─────────────────────────────────────────────────────────────────────────────

model CustomerVerificationToken {
  id           String   @id @default(cuid())
  email        String
  name         String
  phone        String?
  passwordHash String?
  token        String   @unique
  expiresAt    DateTime
  used         Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([email])
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — Measurements
// ─────────────────────────────────────────────────────────────────────────────

model Measurement {
  id         String   @id @default(cuid())
  customerId String
  projectId  String?
  fields     Json     @default("{}") // { chest, waist, hips, ... }
  status     String   @default("pending") // pending | partial | complete | checked
  history    Json     @default("[]") // [{ changedAt, changedBy, snapshot }]
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — Conversations & Messages
// ─────────────────────────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  projectId String
  createdAt DateTime @default(now())

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([projectId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderRole     String // admin | customer
  senderName     String?
  body           String
  isInternal     Boolean   @default(false) // admin-only note, never sent to customer
  readAt         DateTime?
  attachmentUrl  String?
  attachmentType String?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — Notifications
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id         String    @id @default(cuid())
  customerId String? // null = admin notification
  type       String // new_message | status_change | task_due | file_uploaded | new_project
  title      String
  body       String?
  refId      String? // projectId or messageId
  refType    String? // project | message | task
  read       Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  customer Customer? @relation("CustomerNotifications", fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([read])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — Tasks
// ─────────────────────────────────────────────────────────────────────────────

model Task {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  assignedTo  String? // admin user email
  priority    String    @default("normal") // low | normal | high | urgent
  status      String    @default("todo") // todo | in_progress | done | cancelled
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([dueAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — Project Files
// ─────────────────────────────────────────────────────────────────────────────

model ProjectFile {
  id                String   @id @default(cuid())
  projectId         String
  cloudinaryId      String
  url               String
  originalName      String?
  mimeType          String?
  sizeBytes         Int?
  category          String   @default("photo") // offer | invoice | measurement | photo | design | internal | other
  uploadedBy        String   @default("admin") // admin | customer
  description       String?
  /// When false (or category=internal), hidden from customer portal
  visibleToCustomer Boolean  @default(true)
  createdAt         DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([category])
}
