# Copy this file to .env.local and fill in values.
# Generate secrets: openssl rand -base64 32

# Neon PostgreSQL — Dashboard → Connection string (pooled)
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# NextAuth v5 — use the SAME random string for both (openssl rand -base64 32)
AUTH_SECRET=your-generated-secret-here
NEXTAUTH_SECRET=your-generated-secret-here

# Local: http://localhost:3000
# Vercel Production: https://your-domain.com (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Cloudinary — Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Resend — API Keys (optional locally; needed for password-reset emails)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Customer portal cookie signing — openssl rand -base64 32
PORTAL_SESSION_SECRET=your-generated-secret-here

# Admin CMS UI: de (production) or en (local dev)
NEXT_PUBLIC_ADMIN_LOCALE=de
