# Copy this file to .env.local and fill in values.
# Generate secrets: openssl rand -base64 32

# ─── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL — Dashboard → Connection string (pooled)
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# ─── Authentication ───────────────────────────────────────────────────────────
# NextAuth v5 — use the SAME random string for both (openssl rand -base64 32)
AUTH_SECRET=your-generated-secret-here
NEXTAUTH_SECRET=your-generated-secret-here

# Local: http://localhost:3000 | Production: https://your-domain.com (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ─── Customer portal ─────────────────────────────────────────────────────────
# Cookie signing secret — openssl rand -base64 32
PORTAL_SESSION_SECRET=your-generated-secret-here

# ─── Socket.io ───────────────────────────────────────────────────────────────
# Port for the custom Node.js server (default: 3000)
PORT=3000
# Your public app URL used for Socket.io CORS
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cloudinary ──────────────────────────────────────────────────────────────
# Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Resend (email) ──────────────────────────────────────────────────────────
# API Keys at resend.com — required for contact form emails + auto-replies
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The sender address (must be a verified domain in Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Where contact form notifications are sent (e.g. your business email)
CONTACT_NOTIFICATION_EMAIL=kontakt@yourdomain.com

# ─── CMS & Admin ─────────────────────────────────────────────────────────────
# Admin CMS UI language: de (production) or en (local dev)
NEXT_PUBLIC_ADMIN_LOCALE=de
