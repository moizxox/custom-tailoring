# Copy this to .env.local and fill in values

# Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/lani?sslmode=require

# NextAuth (v5 also reads AUTH_SECRET)
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Cloudinary (free tier: 25 GB storage + bandwidth)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email — Resend free tier (for password reset emails)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Customer Portal session secret
PORTAL_SESSION_SECRET=change-me-in-production

# Admin CMS UI language: de (default, for production) or en (for local dev)
# Set NEXT_PUBLIC_ADMIN_LOCALE=en in .env.local to use English admin while developing.
NEXT_PUBLIC_ADMIN_LOCALE=de
