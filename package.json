{
  "name": "lani-kostuemschneiderei",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "dev:next": "next dev",
    "build": "prisma generate && next build",
    "start": "NODE_ENV=production tsx server.ts",
    "start:next": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:seed": "dotenv -e .env.local -- prisma db seed",
    "db:reset-admin": "dotenv -e .env.local -- tsx prisma/reset-admin.ts",
    "db:create-admin": "dotenv -e .env.local -- tsx prisma/create-admin.ts",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "upload:cloudinary": "dotenv -e .env.local -- tsx scripts/upload-to-cloudinary.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.22.0",
    "nanoid": "^5.1.16",
    "next": "^15.3.3",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.13.0",
    "nodemailer": "^9.0.3",
    "prisma": "^6.19.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.16.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0"
  }
}
